<%- include('../partials/header') %>

<div class="form-card">
    <h2>Add New Book Record</h2>
    <form action="/books/create" method="post" style="margin-top: 1.5rem;">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        
        <div class="form-group">
            <label>Book Title</label>
            <input type="text" name="title" required placeholder="e.g., The Way of Kings">
        </div>
        
        <div class="form-group">
            <label>ISBN Code</label>
            <input type="text" name="isbn" required placeholder="e.g., 9780765326355">
        </div>
        
        <div class="form-group">
            <label>Author Assignment</label>
            <select name="author_id" required>
                <option value="">-- Select Author Node --</option>
                <% authors.forEach(author => { %>
                    <option value="<%= author.id %>"><%= author.name %></option>
                <% }) %>
            </select>
        </div>
        
        <div class="form-group">
            <label>Publication Year</label>
            <input type="number" name="publication_year" placeholder="e.g., 2010">
        </div>
        
        <div class="form-group">
            <label>Status</label>
            <select name="status">
                <option value="available" selected>Available</option>
                <option value="borrowed">Borrowed</option>
                <option value="reserved">Reserved</option>
            </select>
        </div>
        
        <div class="form-group">
            <label>Description</label>
            <textarea name="description" rows="4" placeholder="Enter full abstract overview copy..."></textarea>
        </div>
        
        <div class="row-actions" style="margin-top: 2rem;">
            <button type="submit" class="btn btn-primary" style="background-color: var(--success);">Save to Catalog</button>
            <a href="/books/admin-dashboard" class="btn btn-secondary">Cancel</a>
        </div>
    </form>
</div>