<%- include('../partials/header') %>

<div class="form-card">
    <h2>Register New Author</h2>
    <form action="/authors/create" method="post" style="margin-top: 1.5rem;">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        
        <div class="form-group">
            <label>Author Full Name</label>
            <input type="text" name="name" required placeholder="e.g., Brandon Sanderson">
        </div>
        
        <div class="form-group">
            <label>Nationality</label>
            <input type="text" name="nationality" placeholder="e.g., American">
        </div>
        
        <div class="form-group">
            <label>Birth Year</label>
            <input type="number" name="birth_year" placeholder="e.g., 1975">
        </div>
        
        <div class="form-group">
            <label>Biography</label>
            <textarea name="biography" rows="4" placeholder="Enter summary bio timeline metadata..."></textarea>
        </div>
        
        <div class="row-actions" style="margin-top: 2rem;">
            <button type="submit" class="btn btn-primary" style="background-color: var(--success);">Save Author</button>
            <a href="/authors" class="btn btn-secondary">Cancel</a>
        </div>
    </form>
</div>